{
  "expo": {
    "name": "Convex Mobile Template",
    "slug": "convex-mobile-template",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.convextemplate.mobile"
    },
    "android": {
      "package": "com.convextemplate.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "expo-dev-client"
    ],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": false
    }
  }
}
